---
// Header.astro — Reformas Baño Madrid Pro
// Top bar oscura + navegación principal con hubs del Doc A 2.3
const navItems = [
  { label: 'Inicio', href: '/' },
  {
    label: 'Servicios',
    href: '/servicios/',
    children: [
      { label: 'Reforma Integral de Baño', href: '/servicios/reforma-integral-bano/' },
      { label: 'Cambio de Bañera por Ducha', href: '/servicios/cambio-banera-por-ducha/' },
      { label: 'Instalación de Mamparas', href: '/servicios/instalacion-mamparas/' },
      { label: 'Muebles de Baño a Medida', href: '/servicios/muebles-bano-a-medida/' },
      { label: 'Reforma Sin Obra', href: '/servicios/reforma-sin-obra/' },
    ],
  },
  {
    label: 'Zonas',
    href: '/zonas/',
    children: [
      { label: 'Reforma de Baño en Madrid', href: '/zonas/madrid/' },
      { label: 'Reforma de Baño en Moncloa', href: '/zonas/madrid/moncloa/' },
      { label: 'Reforma de Baño en Argüelles', href: '/zonas/madrid/arguelles/' },
    ],
  },
  { label: 'Proyectos', href: '/proyectos/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Nosotros', href: '/nosotros/' },
  { label: 'Presupuesto', href: '/presupuesto/' },
];
---

<!-- Top bar -->
<div class="bg-[#151515] text-white text-xs py-2">
  <div class="container-main flex justify-between items-center">
    <span class="flex items-center gap-1">
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
      info@reformasbanomadridpro.es
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
      910 12 34 56
    </span>
  </div>
</div>

<!-- Header principal -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="container-main flex items-center justify-between py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <span class="text-2xl font-bold text-[#151515]">Reformas<span class="text-[#B30000]">Baño</span></span>
      <span class="text-xs text-gray-500 hidden sm:block">Madrid Pro</span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden lg:flex items-center gap-6">
      {navItems.map((item) => (
        <div class="relative group">
          <a
            href={item.href}
            class="text-sm text-[#303035] hover:text-[#B30000] transition-colors duration-200 font-medium py-2"
          >
            {item.label}
            {item.children && <span class="ml-1 text-xs">▾</span>}
          </a>
          {item.children && (
            <div class="absolute top-full left-0 bg-white shadow-lg border-t-2 border-[#B30000] min-w-[220px] hidden group-hover:block z-50">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block px-4 py-3 text-sm text-[#303035] hover:bg-[#F6F6F6] hover:text-[#B30000] transition-colors duration-150"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- CTA teléfono -->
    <a href="tel:+34910123456" class="hidden lg:flex items-center gap-2 btn-primary text-sm px-6 py-3">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
      910 12 34 56
    </a>

    <!-- Menú móvil (hamburger) -->
    <button
      id="menu-toggle"
      class="lg:hidden p-2 text-[#303035]"
      aria-label="Abrir menú"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Menú móvil desplegable -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 px-4 pb-4">
    {navItems.map((item) => (
      <div>
        <a href={item.href} class="block py-3 text-sm font-medium text-[#303035] border-b border-gray-100 hover:text-[#B30000]">
          {item.label}
        </a>
        {item.children && item.children.map((child) => (
          <a href={child.href} class="block py-2 pl-4 text-sm text-gray-500 hover:text-[#B30000]">
            {child.label}
          </a>
        ))}
      </div>
    ))}
    <a href="tel:+34910123456" class="btn-primary mt-4 text-center block">
      910 12 34 56
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
