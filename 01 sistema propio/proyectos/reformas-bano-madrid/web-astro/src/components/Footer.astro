---
// Footer.astro — Reformas Baño Madrid Pro
// Fondo #0B0B0B, 3 columnas: logo+datos / servicios / información
---

<!-- Pre-footer contacto -->
<div class="bg-[#F6F6F6] py-10">
  <div class="container-main flex flex-col md:flex-row items-center gap-6">
    <div class="md:w-1/3">
      <img
        src="https://d2xsxph8kpxj0f.cloudfront.net/310519663319194189/GtDWXkEw3HZjzzH6Ch3b8h/bathroom-gallery-1-Uvk9yuCwaxcjRzCnVZQ6gX.webp"
        alt="Baño reformado en Madrid"
        class="w-full h-40 object-cover rounded-[4px]"
      />
    </div>
    <div class="md:w-2/3">
      <h3 class="text-xl font-semibold text-[#151515] mb-2">Contacta con Reformas Baño Madrid Pro</h3>
      <p class="text-sm text-gray-600 mb-4">Estamos disponibles por teléfono, email o a través de nuestro formulario en la web.</p>
      <div class="flex flex-wrap gap-4 text-sm">
        <a href="tel:+34910123456" class="flex items-center gap-2 text-[#B30000] font-medium">📞 910 12 34 56</a>
        <a href="https://wa.me/34910123456" class="flex items-center gap-2 text-[#B30000] font-medium">💬 WhatsApp</a>
      </div>
    </div>
  </div>
</div>

<!-- Footer principal -->
<footer class="bg-[#0B0B0B] text-gray-400 pt-12 pb-6">
  <div class="container-main grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
    <!-- Col 1: Logo + datos -->
    <div>
      <a href="/" class="inline-block mb-4">
        <span class="text-xl font-bold text-white">Reformas<span class="text-[#B30000]">Baño</span></span>
        <span class="text-xs text-gray-500 block">Madrid Pro</span>
      </a>
      <address class="not-italic text-sm space-y-1">
        <p>Calle de la Princesa 45</p>
        <p>28008 Madrid</p>
        <p><a href="mailto:info@reformasbanomadridpro.es" class="hover:text-[#B30000] transition-colors">info@reformasbanomadridpro.es</a></p>
        <p><a href="tel:+34910123456" class="hover:text-[#B30000] transition-colors">910 12 34 56</a></p>
      </address>
    </div>

    <!-- Col 2: Servicios -->
    <div>
      <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Servicios</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/servicios/reforma-integral-bano/" class="hover:text-[#B30000] transition-colors">Reforma Integral de Baño</a></li>
        <li><a href="/servicios/cambio-banera-por-ducha/" class="hover:text-[#B30000] transition-colors">Cambio de Bañera por Ducha</a></li>
        <li><a href="/servicios/instalacion-mamparas/" class="hover:text-[#B30000] transition-colors">Instalación de Mamparas</a></li>
        <li><a href="/servicios/muebles-bano-a-medida/" class="hover:text-[#B30000] transition-colors">Muebles de Baño a Medida</a></li>
        <li><a href="/servicios/reforma-sin-obra/" class="hover:text-[#B30000] transition-colors">Reforma Sin Obra</a></li>
        <li><a href="/zonas/madrid/" class="hover:text-[#B30000] transition-colors">Reformas en Madrid</a></li>
        <li><a href="/zonas/madrid/arguelles/" class="hover:text-[#B30000] transition-colors">Reformas en Argüelles</a></li>
        <li><a href="/zonas/madrid/moncloa/" class="hover:text-[#B30000] transition-colors">Reformas en Moncloa</a></li>
      </ul>
    </div>

    <!-- Col 3: Información -->
    <div>
      <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Información</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/nosotros/" class="hover:text-[#B30000] transition-colors">Quiénes somos</a></li>
        <li><a href="/proyectos/" class="hover:text-[#B30000] transition-colors">Proyectos realizados</a></li>
        <li><a href="/blog/" class="hover:text-[#B30000] transition-colors">Blog</a></li>
        <li><a href="/presupuesto/" class="hover:text-[#B30000] transition-colors">Presupuesto online</a></li>
        <li><a href="/aviso-legal/" class="hover:text-[#B30000] transition-colors">Aviso legal</a></li>
        <li><a href="/politica-privacidad/" class="hover:text-[#B30000] transition-colors">Política de privacidad</a></li>
      </ul>
    </div>
  </div>

  <div class="container-main border-t border-gray-800 pt-6 text-xs text-center text-gray-600">
    © 2026 Reformas Baño Madrid Pro. Todos los derechos reservados.
  </div>
</footer>
