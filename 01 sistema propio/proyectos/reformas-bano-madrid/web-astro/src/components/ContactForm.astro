---
// ContactForm.astro — Formulario de presupuesto
// Doc C: Fondo #151515, inputs con borde inferior, labels uppercase
interface Props {
  title?: string;
  subtitle?: string;
  zona?: string;
}

const {
  title = 'Pide tu presupuesto sin compromiso',
  subtitle = 'Cuéntanos tu proyecto y te respondemos en menos de 24 horas con un presupuesto detallado y sin sorpresas.',
  zona = '',
} = Astro.props;
---

<section class="section-dark py-16">
  <div class="container-main">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-medium text-white">{title}</h2>
        <span class="block w-28 h-0.5 bg-[#B30000] mx-auto mt-3 mb-4"></span>
        <p class="text-sm text-white/60">{subtitle}</p>
      </div>

      <form
        action="https://formspree.io/f/reformasbanomadridpro"
        method="POST"
        class="space-y-6"
      >
        {zona && <input type="hidden" name="zona" value={zona} />}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Nombre *</label>
            <input type="text" name="nombre" placeholder="Tu nombre" required class="form-input-dark" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Teléfono *</label>
            <input type="tel" name="telefono" placeholder="Tu teléfono" required class="form-input-dark" />
          </div>
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Email</label>
          <input type="email" name="email" placeholder="tu@email.com" class="form-input-dark" />
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Servicio de interés</label>
          <select name="servicio" class="form-input-dark appearance-none">
            <option value="">Elige una opción</option>
            <option value="reforma-integral">Reforma Integral de Baño</option>
            <option value="cambio-banera">Cambio Bañera por Ducha</option>
            <option value="mamparas">Instalación de Mamparas</option>
            <option value="muebles">Muebles de Baño a Medida</option>
            <option value="reforma-sin-obra">Reforma Sin Obra</option>
            <option value="otro">Otro</option>
          </select>
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Mensaje</label>
          <textarea name="mensaje" placeholder="Cuéntanos tu proyecto..." rows="3" class="form-input-dark resize-none"></textarea>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 items-center pt-2">
          <button type="submit" class="btn-primary w-full sm:w-auto">
            Solicitar presupuesto
          </button>
          <a href="tel:+34910123456" class="flex items-center gap-2 text-sm text-white/60">
            <svg class="w-4 h-4 text-[#B30000]" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
            O llámanos al <strong class="text-white">910 12 34 56</strong>
          </a>
        </div>
      </form>
    </div>
  </div>
</section>
