---
import Layout from '@layouts/Layout.astro';
import ContactForm from '@components/ContactForm.astro';
---
<Layout title="Presupuesto Online Reforma de Baño Madrid | Reformas Baño Madrid Pro" description="Solicita tu presupuesto de reforma de baño en Madrid sin compromiso. Respuesta en menos de 24 horas. ☎ 910 12 34 56" canonical="/presupuesto/">
  <section class="py-16 bg-[#F6F6F6]">
    <div class="container-main max-w-2xl text-center">
      <h1 class="text-4xl font-bold text-[#151515] mb-4">Presupuesto Online</h1>
      <p class="text-gray-600 mb-2">Rellena el formulario y te enviamos un presupuesto detallado en menos de 24 horas.</p>
      <p class="text-gray-600">También puedes llamarnos directamente al <a href="tel:+34910123456" class="text-[#B30000] font-semibold">910 12 34 56</a></p>
    </div>
  </section>
  <ContactForm title="Solicita tu presupuesto" subtitle="Cuéntanos qué necesitas y te preparamos un presupuesto cerrado sin sorpresas." />
  <section class="py-12 bg-white">
    <div class="container-main max-w-3xl">
      <h2 class="text-2xl font-medium text-[#151515] section-title mb-8">Precios orientativos</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead><tr class="bg-[#151515] text-white"><th class="text-left p-3">Servicio</th><th class="text-right p-3">Precio desde</th></tr></thead>
          <tbody>
            <tr class="border-b border-gray-200"><td class="p-3">Cambio de bañera por ducha</td><td class="p-3 text-right font-bold text-[#B30000]">1.199€</td></tr>
            <tr class="border-b border-gray-200 bg-[#F6F6F6]"><td class="p-3">Reforma sin obra</td><td class="p-3 text-right font-bold text-[#B30000]">799€</td></tr>
            <tr class="border-b border-gray-200"><td class="p-3">Instalación de mamparas</td><td class="p-3 text-right font-bold text-[#B30000]">450€</td></tr>
            <tr class="border-b border-gray-200 bg-[#F6F6F6]"><td class="p-3">Muebles de baño a medida</td><td class="p-3 text-right font-bold text-[#B30000]">890€</td></tr>
            <tr><td class="p-3">Reforma integral de baño</td><td class="p-3 text-right font-bold text-[#B30000]">6.995€</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-4">* Precios orientativos. El precio final depende de las dimensiones, materiales y trabajos a realizar. Solicita tu presupuesto personalizado.</p>
    </div>
  </section>
</Layout>
