---
import Layout from '@layouts/Layout.astro';
import ContactForm from '@components/ContactForm.astro';
import FAQ from '@components/FAQ.astro';
import { SERVICES, LOCATIONS, SITE } from '@data/site';

const loc = LOCATIONS.find(l => l.slug === 'madrid')!;
const faqs = [{"question": "¿Cuánto cuesta reformar un baño en Madrid?", "answer": "El precio de reformar un baño en Madrid varía entre 1.199€ para un cambio de bañera y 15.000€ para una reforma integral completa. El precio depende de los metros cuadrados, los materiales y los trabajos a realizar."}, {"question": "¿Cuánto tiempo tarda una reforma de baño en Madrid?", "answer": "Una reforma de baño en Madrid puede durar desde 48 horas (cambio de bañera por ducha) hasta 20 días laborables (reforma integral completa)."}, {"question": "¿Trabajáis en toda la ciudad de Madrid?", "answer": "Sí, trabajamos en toda la ciudad de Madrid, con especial presencia en los barrios de Argüelles y Moncloa. También realizamos trabajos en otros distritos de la capital."}];

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "url": SITE.url + "/zonas/madrid/",
  "telephone": SITE.phoneE164,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Madrid",
    "addressRegion": "Madrid",
    "addressCountry": "ES"
  },
  "areaServed": "Madrid"
};
---

<Layout
  title="Reforma de Baño en Madrid | Reformas Baño Madrid Pro"
  description="Empresa de reforma de baño en Madrid. Especialistas en Argüelles y Moncloa. Cambio de bañera desde 1.199€. ☎ 910 12 34 56"
  canonical="/zonas/madrid/"
  schema={schema}
>
  <!-- HERO -->
  <section class="relative h-[420px] flex items-end">
    <img src={loc.heroImage} alt={loc.title} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative container-main pb-12 text-white">
      <div class="bg-[#B30000] inline-block px-3 py-1 text-xs font-bold uppercase tracking-wide mb-3">MADRID</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">Reforma de Baño en Madrid</h1>
      <p class="text-lg text-gray-200 mb-6 max-w-xl">Más de 500 baños reformados en Madrid. Presupuesto sin compromiso en 24h.</p>
      <a href="/presupuesto/" class="btn-primary">Pedir Presupuesto</a>
    </div>
  </section>

  <!-- CONTEXTO LOCAL -->
  <section class="py-16 bg-white">
    <div class="container-main flex flex-col lg:flex-row gap-12 items-center">
      <div class="lg:w-1/2">
        <h2 class="text-3xl font-medium text-[#151515] section-title mb-6">Reformas de baño en Madrid</h2>
        <p class="text-gray-600 mb-4">{loc.context}</p>
        <p class="text-gray-600 mb-6">En Reformas Baño Madrid Pro conocemos bien las características de las viviendas de Madrid y ofrecemos soluciones adaptadas a cada caso.</p>
        <a href="/presupuesto/" class="btn-primary">Solicitar presupuesto en Madrid</a>
      </div>
      <div class="lg:w-1/2">
        <img src={loc.heroImage} alt="Reforma de baño en Madrid" class="w-full h-64 object-cover rounded-[4px]" />
      </div>
    </div>
  </section>

  <!-- SERVICIOS EN ESTA ZONA -->
  <section class="py-16 bg-[#F6F6F6]">
    <div class="container-main">
      <h2 class="text-3xl font-medium text-[#151515] section-title mb-10">Servicios de reforma de baño en Madrid</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {SERVICES.map((service) => (
          <a href={`/servicios/${service.slug}/`} class="service-card group block">
            <div class="overflow-hidden rounded-[4px] mb-4 h-40">
              <img src={service.heroImage} alt={service.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            </div>
            <h3 class="text-base font-semibold text-[#151515] group-hover:text-[#B30000] transition-colors mb-2">{service.title}</h3>
            <p class="text-[#B30000] font-bold text-sm">{service.price}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FORMULARIO -->
  <ContactForm title="Presupuesto de reforma de baño en Madrid" subtitle="Somos especialistas en Madrid. Te contactamos en menos de 24h." zona="madrid" />

  <!-- FAQ -->
  <FAQ items={faqs} title="Preguntas frecuentes sobre reformas de baño en Madrid" />
</Layout>
