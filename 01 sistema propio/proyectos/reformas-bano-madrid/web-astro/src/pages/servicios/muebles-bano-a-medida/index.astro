---
import Layout from '@layouts/Layout.astro';
import ContactForm from '@components/ContactForm.astro';
import FAQ from '@components/FAQ.astro';
import { SERVICES, SITE } from '@data/site';

const service = SERVICES.find(s => s.slug === 'muebles-bano-a-medida')!;

const faqs = [{"question": "¿Cuánto cuesta un mueble de baño a medida en Madrid?", "answer": "El precio de un mueble de baño a medida en Madrid empieza desde 890€ para un mueble de un módulo con lavabo. El precio final depende de las dimensiones, los materiales y los acabados elegidos."}, {"question": "¿Cuánto tiempo tarda la fabricación de un mueble a medida?", "answer": "El plazo de fabricación de un mueble de baño a medida es de 15 a 20 días laborables desde la confirmación del pedido. La instalación se realiza en un solo día."}, {"question": "¿Qué materiales usáis para los muebles de baño?", "answer": "Utilizamos tableros hidrófugos de alta densidad resistentes a la humedad, herrajes de cierre suave y encimeras de porcelana, madera o resina mineral según la elección del cliente."}];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "provider": { "@type": "LocalBusiness", "name": SITE.name },
  "areaServed": "Madrid",
  "offers": { "@type": "Offer", "priceCurrency": "EUR", "price": "890" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<Layout
  title="Muebles de Baño a Medida en Madrid | Reformas Baño Madrid Pro"
  description="Muebles de baño a medida en Madrid desde 890€. Diseño personalizado, máximo aprovechamiento del espacio. Especialistas en Argüelles y Moncloa."
  canonical="/servicios/muebles-bano-a-medida/"
  schema={[schema, faqSchema]}
>
  <!-- HERO -->
  <section class="relative h-[420px] flex items-end">
    <img src={service.heroImage} alt={service.title} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative container-main pb-12 text-white">
      <div class="bg-[#B30000] inline-block px-3 py-1 text-xs font-bold uppercase tracking-wide mb-3">MADRID · ARGÜELLES · MONCLOA</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">Muebles de Baño a Medida en Madrid</h1>
      <p class="text-lg text-gray-200 mb-6 max-w-xl">Muebles de baño personalizados. Aprovecha cada centímetro de tu espacio con diseño a medida.</p>
      <div class="flex flex-wrap gap-4 items-center">
        <a href="/presupuesto/" class="btn-primary">Pedir Presupuesto</a>
        <span class="text-2xl font-bold text-white">Desde 890€</span>
      </div>
    </div>
  </section>

  <!-- VENTAJAS -->
  <section class="py-16 bg-white">
    <div class="container-main">
      <h2 class="text-3xl font-medium text-[#151515] section-title mb-10">Ventajas de nuestro servicio</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="service-card text-center">
          <div class="text-4xl mb-3">📐</div>
          <h3 class="font-semibold text-[#151515] mb-2">Diseño personalizado</h3>
          <p class="text-sm text-gray-600">Cada mueble se diseña y fabrica a la medida exacta de tu baño.</p>
        </div>
        <div class="service-card text-center">
          <div class="text-4xl mb-3">🪵</div>
          <h3 class="font-semibold text-[#151515] mb-2">Materiales de calidad</h3>
          <p class="text-sm text-gray-600">Tableros hidrófugos, herrajes de calidad y acabados premium.</p>
        </div>
        <div class="service-card text-center">
          <div class="text-4xl mb-3">🔧</div>
          <h3 class="font-semibold text-[#151515] mb-2">Instalación incluida</h3>
          <p class="text-sm text-gray-600">Instalamos el mueble con todos sus accesorios y conexiones.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMULARIO -->
  <ContactForm title="Pide tu presupuesto para Muebles a Medida" subtitle="Presupuesto cerrado, sin sorpresas. Te contactamos en menos de 24h." zona="muebles-bano-a-medida" />

  <!-- QUÉ INCLUYE -->
  <section class="py-16 bg-[#F6F6F6]">
    <div class="container-main flex flex-col lg:flex-row gap-12 items-start">
      <div class="lg:w-1/2">
        <h2 class="text-3xl font-medium text-[#151515] section-title mb-6">Qué incluye nuestro servicio</h2>
        <ul class="space-y-3 text-sm text-gray-700">
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Diseño personalizado según las medidas de tu baño</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Fabricación en tablero hidrófugo de alta resistencia</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Encimera de porcelana, madera o resina según elección</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Lavabo integrado o sobre encimera</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Herrajes de cierre suave y cajones con guías telescópicas</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Instalación completa con conexión de fontanería</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Espejo y apliques de iluminación opcionales</li>
        </ul>
      </div>
      <div class="lg:w-1/2">
        <img src={service.heroImage} alt="Detalle de Muebles a Medida en Madrid" class="w-full h-64 object-cover rounded-[4px]" />
      </div>
    </div>
  </section>

  <!-- DIFERENCIADORES -->
  <section class="py-16 bg-white">
    <div class="container-main">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div><div class="text-4xl mb-3">🏆</div><h3 class="font-semibold text-[#151515] mb-2">Garantía 5 años</h3><p class="text-sm text-gray-600">Garantía completa por escrito en todos nuestros trabajos.</p></div>
        <div><div class="text-4xl mb-3">⚡</div><h3 class="font-semibold text-[#151515] mb-2">Rapidez</h3><p class="text-sm text-gray-600">Plazos de entrega cumplidos. Cambio de bañera en 48h.</p></div>
        <div><div class="text-4xl mb-3">💳</div><h3 class="font-semibold text-[#151515] mb-2">Financiación sin intereses</h3><p class="text-sm text-gray-600">Financia tu reforma sin intereses hasta en 12 meses.</p></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={faqs} title="Preguntas frecuentes sobre Muebles a Medida en Madrid" />

  <!-- ZONAS -->
  <section class="py-12 bg-[#F6F6F6]">
    <div class="container-main">
      <h2 class="text-2xl font-medium text-[#151515] section-title mb-8">Dónde realizamos este servicio</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/zonas/madrid/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Madrid</a>
        <a href="/zonas/madrid/moncloa/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Moncloa</a>
        <a href="/zonas/madrid/arguelles/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Argüelles</a>
      </div>
    </div>
  </section>
</Layout>
