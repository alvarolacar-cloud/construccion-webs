---
import Layout from '@layouts/Layout.astro';
import ContactForm from '@components/ContactForm.astro';
import FAQ from '@components/FAQ.astro';
import { SERVICES, SITE } from '@data/site';

const service = SERVICES.find(s => s.slug === 'instalacion-mamparas')!;

const faqs = [{"question": "¿Cuánto cuesta instalar una mampara de baño en Madrid?", "answer": "El precio de instalación de una mampara de baño en Madrid empieza desde 450€ para una mampara fija de una hoja. Las mamparas plegables o correderas tienen un precio mayor según las dimensiones."}, {"question": "¿Qué grosor de cristal recomendáis para una mampara?", "answer": "Recomendamos cristal templado de 6mm para mamparas estándar y 8mm para mamparas de gran formato o sin perfilería. El cristal templado es mucho más resistente y seguro que el cristal normal."}, {"question": "¿Cuánto tiempo tarda la instalación de una mampara?", "answer": "La instalación de una mampara de baño se realiza en un solo día. El plazo de fabricación es de 7 a 10 días laborables desde la confirmación del pedido."}];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "provider": { "@type": "LocalBusiness", "name": SITE.name },
  "areaServed": "Madrid",
  "offers": { "@type": "Offer", "priceCurrency": "EUR", "price": "450" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<Layout
  title="Instalación de Mamparas de Baño en Madrid | Reformas Baño Madrid Pro"
  description="Instalación de mamparas de baño en Madrid desde 450€. Cristal templado 6-8mm a medida. Especialistas en Argüelles y Moncloa."
  canonical="/servicios/instalacion-mamparas/"
  schema={[schema, faqSchema]}
>
  <!-- HERO -->
  <section class="relative h-[420px] flex items-end">
    <img src={service.heroImage} alt={service.title} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative container-main pb-12 text-white">
      <div class="bg-[#B30000] inline-block px-3 py-1 text-xs font-bold uppercase tracking-wide mb-3">MADRID · ARGÜELLES · MONCLOA</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">Instalación de Mamparas de Baño en Madrid</h1>
      <p class="text-lg text-gray-200 mb-6 max-w-xl">Mamparas de cristal templado 6-8mm a medida. Perfilería en aluminio anodizado o lacado.</p>
      <div class="flex flex-wrap gap-4 items-center">
        <a href="/presupuesto/" class="btn-primary">Pedir Presupuesto</a>
        <span class="text-2xl font-bold text-white">Desde 450€</span>
      </div>
    </div>
  </section>

  <!-- VENTAJAS -->
  <section class="py-16 bg-white">
    <div class="container-main">
      <h2 class="text-3xl font-medium text-[#151515] section-title mb-10">Ventajas de nuestro servicio</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="service-card text-center">
          <div class="text-4xl mb-3">🔒</div>
          <h3 class="font-semibold text-[#151515] mb-2">Cristal templado 6-8mm</h3>
          <p class="text-sm text-gray-600">Máxima seguridad y resistencia. Cristal templado de alta calidad.</p>
        </div>
        <div class="service-card text-center">
          <div class="text-4xl mb-3">📐</div>
          <h3 class="font-semibold text-[#151515] mb-2">A medida</h3>
          <p class="text-sm text-gray-600">Fabricamos la mampara a la medida exacta de tu baño o ducha.</p>
        </div>
        <div class="service-card text-center">
          <div class="text-4xl mb-3">✨</div>
          <h3 class="font-semibold text-[#151515] mb-2">Fácil limpieza</h3>
          <p class="text-sm text-gray-600">Tratamiento antical opcional para una limpieza más fácil y duradera.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMULARIO -->
  <ContactForm title="Pide tu presupuesto para Mamparas" subtitle="Presupuesto cerrado, sin sorpresas. Te contactamos en menos de 24h." zona="instalacion-mamparas" />

  <!-- QUÉ INCLUYE -->
  <section class="py-16 bg-[#F6F6F6]">
    <div class="container-main flex flex-col lg:flex-row gap-12 items-start">
      <div class="lg:w-1/2">
        <h2 class="text-3xl font-medium text-[#151515] section-title mb-6">Qué incluye nuestro servicio</h2>
        <ul class="space-y-3 text-sm text-gray-700">
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Medición y presupuesto sin compromiso</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Fabricación a medida en cristal templado 6-8mm</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Perfilería en aluminio anodizado o lacado en el color elegido</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Instalación por técnicos especializados</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Sellado perimetral con silicona sanitaria</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Tratamiento antical opcional</li>
        </ul>
      </div>
      <div class="lg:w-1/2">
        <img src={service.heroImage} alt="Detalle de Mamparas en Madrid" class="w-full h-64 object-cover rounded-[4px]" />
      </div>
    </div>
  </section>

  <!-- DIFERENCIADORES -->
  <section class="py-16 bg-white">
    <div class="container-main">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div><div class="text-4xl mb-3">🏆</div><h3 class="font-semibold text-[#151515] mb-2">Garantía 5 años</h3><p class="text-sm text-gray-600">Garantía completa por escrito en todos nuestros trabajos.</p></div>
        <div><div class="text-4xl mb-3">⚡</div><h3 class="font-semibold text-[#151515] mb-2">Rapidez</h3><p class="text-sm text-gray-600">Plazos de entrega cumplidos. Cambio de bañera en 48h.</p></div>
        <div><div class="text-4xl mb-3">💳</div><h3 class="font-semibold text-[#151515] mb-2">Financiación sin intereses</h3><p class="text-sm text-gray-600">Financia tu reforma sin intereses hasta en 12 meses.</p></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={faqs} title="Preguntas frecuentes sobre Mamparas en Madrid" />

  <!-- ZONAS -->
  <section class="py-12 bg-[#F6F6F6]">
    <div class="container-main">
      <h2 class="text-2xl font-medium text-[#151515] section-title mb-8">Dónde realizamos este servicio</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/zonas/madrid/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Madrid</a>
        <a href="/zonas/madrid/moncloa/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Moncloa</a>
        <a href="/zonas/madrid/arguelles/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Argüelles</a>
      </div>
    </div>
  </section>
</Layout>
