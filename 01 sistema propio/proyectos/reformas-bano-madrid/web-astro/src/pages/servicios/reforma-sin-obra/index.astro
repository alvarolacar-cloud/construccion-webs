---
import Layout from '@layouts/Layout.astro';
import ContactForm from '@components/ContactForm.astro';
import FAQ from '@components/FAQ.astro';
import { SERVICES, SITE } from '@data/site';

const service = SERVICES.find(s => s.slug === 'reforma-sin-obra')!;

const faqs = [{"question": "¿Qué es una reforma de baño sin obra?", "answer": "Una reforma de baño sin obra consiste en renovar el aspecto del baño sin demoler el alicatado existente. Se colocan nuevos revestimientos sobre los existentes, se cambian los sanitarios y la grifería, obteniendo un resultado completamente renovado sin escombros ni ruido."}, {"question": "¿Cuánto cuesta una reforma de baño sin obra en Madrid?", "answer": "El precio de una reforma de baño sin obra en Madrid empieza desde 799€. Al no haber demolición ni gestión de escombros, el coste es significativamente menor que una reforma integral."}, {"question": "¿La reforma sin obra es tan duradera como la reforma tradicional?", "answer": "Los materiales actuales para reforma sin obra tienen una durabilidad muy alta. Los revestimientos sobre alicatado existente pueden durar más de 15 años con un mantenimiento adecuado."}];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "provider": { "@type": "LocalBusiness", "name": SITE.name },
  "areaServed": "Madrid",
  "offers": { "@type": "Offer", "priceCurrency": "EUR", "price": "799" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<Layout
  title="Reforma de Baño Sin Obra en Madrid | Reformas Baño Madrid Pro"
  description="Reforma de baño sin obra en Madrid desde 799€. Sin escombros, sin ruido, instalación en 1 día. Especialistas en Argüelles y Moncloa."
  canonical="/servicios/reforma-sin-obra/"
  schema={[schema, faqSchema]}
>
  <!-- HERO -->
  <section class="relative h-[420px] flex items-end">
    <img src={service.heroImage} alt={service.title} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative container-main pb-12 text-white">
      <div class="bg-[#B30000] inline-block px-3 py-1 text-xs font-bold uppercase tracking-wide mb-3">MADRID · ARGÜELLES · MONCLOA</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">Reforma de Baño Sin Obra en Madrid</h1>
      <p class="text-lg text-gray-200 mb-6 max-w-xl">Renueva tu baño sin escombros ni ruido. Revestimientos sobre el existente, instalación en 1 día.</p>
      <div class="flex flex-wrap gap-4 items-center">
        <a href="/presupuesto/" class="btn-primary">Pedir Presupuesto</a>
        <span class="text-2xl font-bold text-white">Desde 799€</span>
      </div>
    </div>
  </section>

  <!-- VENTAJAS -->
  <section class="py-16 bg-white">
    <div class="container-main">
      <h2 class="text-3xl font-medium text-[#151515] section-title mb-10">Ventajas de nuestro servicio</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="service-card text-center">
          <div class="text-4xl mb-3">🔇</div>
          <h3 class="font-semibold text-[#151515] mb-2">Sin ruido ni escombros</h3>
          <p class="text-sm text-gray-600">Renovamos tu baño sin demolición. Sin polvo, sin ruido, sin molestias.</p>
        </div>
        <div class="service-card text-center">
          <div class="text-4xl mb-3">⚡</div>
          <h3 class="font-semibold text-[#151515] mb-2">Instalación en 1 día</h3>
          <p class="text-sm text-gray-600">En un solo día tienes tu baño completamente renovado.</p>
        </div>
        <div class="service-card text-center">
          <div class="text-4xl mb-3">💰</div>
          <h3 class="font-semibold text-[#151515] mb-2">Precio reducido</h3>
          <p class="text-sm text-gray-600">Al no haber obra, el coste es significativamente menor que una reforma tradicional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMULARIO -->
  <ContactForm title="Pide tu presupuesto para Reforma Sin Obra" subtitle="Presupuesto cerrado, sin sorpresas. Te contactamos en menos de 24h." zona="reforma-sin-obra" />

  <!-- QUÉ INCLUYE -->
  <section class="py-16 bg-[#F6F6F6]">
    <div class="container-main flex flex-col lg:flex-row gap-12 items-start">
      <div class="lg:w-1/2">
        <h2 class="text-3xl font-medium text-[#151515] section-title mb-6">Qué incluye nuestro servicio</h2>
        <ul class="space-y-3 text-sm text-gray-700">
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Revestimiento de paredes sobre el alicatado existente</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Suelo vinílico o laminado resistente al agua</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Cambio de sanitarios sin modificar fontanería</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Nueva grifería y accesorios</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Mampara o cortina de ducha nueva</li>
          <li class="flex items-center gap-2"><span class="text-[#B30000] font-bold">✓</span> Sellado de juntas y acabados</li>
        </ul>
      </div>
      <div class="lg:w-1/2">
        <img src={service.heroImage} alt="Detalle de Reforma Sin Obra en Madrid" class="w-full h-64 object-cover rounded-[4px]" />
      </div>
    </div>
  </section>

  <!-- DIFERENCIADORES -->
  <section class="py-16 bg-white">
    <div class="container-main">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div><div class="text-4xl mb-3">🏆</div><h3 class="font-semibold text-[#151515] mb-2">Garantía 5 años</h3><p class="text-sm text-gray-600">Garantía completa por escrito en todos nuestros trabajos.</p></div>
        <div><div class="text-4xl mb-3">⚡</div><h3 class="font-semibold text-[#151515] mb-2">Rapidez</h3><p class="text-sm text-gray-600">Plazos de entrega cumplidos. Cambio de bañera en 48h.</p></div>
        <div><div class="text-4xl mb-3">💳</div><h3 class="font-semibold text-[#151515] mb-2">Financiación sin intereses</h3><p class="text-sm text-gray-600">Financia tu reforma sin intereses hasta en 12 meses.</p></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={faqs} title="Preguntas frecuentes sobre Reforma Sin Obra en Madrid" />

  <!-- ZONAS -->
  <section class="py-12 bg-[#F6F6F6]">
    <div class="container-main">
      <h2 class="text-2xl font-medium text-[#151515] section-title mb-8">Dónde realizamos este servicio</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/zonas/madrid/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Madrid</a>
        <a href="/zonas/madrid/moncloa/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Moncloa</a>
        <a href="/zonas/madrid/arguelles/" class="inline-block border border-[#B30000] text-[#B30000] px-4 py-2 text-sm hover:bg-[#B30000] hover:text-white transition-colors">Argüelles</a>
      </div>
    </div>
  </section>
</Layout>
