{
  "$schema": "./design.tokens.schema.json",
  "meta": {
    "project": "{{project_slug}}",
    "version": "2.0.0",
    "sourceOfTruth": "DOC_C"
  },
  "layout": {
    "maxWidth": "1200px",
    "contentWidth": "760px",
    "headerHeight": "80px",
    "sectionSpacingDesktop": "4rem",
    "sectionSpacingMobile": "2.5rem"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem",
    "3xl": "4rem"
  },
  "radius": {
    "sm": "6px",
    "md": "12px",
    "lg": "20px",
    "pill": "999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,.08)",
    "md": "0 8px 24px rgba(0,0,0,.10)",
    "lg": "0 18px 48px rgba(0,0,0,.14)"
  },
  "typography": {
    "fontFamilyBase": "{{font_family_base}}",
    "fontFamilyHeading": "{{font_family_heading}}",
    "fontWeightRegular": 400,
    "fontWeightMedium": 500,
    "fontWeightSemibold": 600,
    "fontWeightBold": 700,
    "sizes": {
      "h1": {
        "desktop": "3rem",
        "mobile": "2.25rem",
        "lineHeight": 1.1
      },
      "h2": {
        "desktop": "2rem",
        "mobile": "1.625rem",
        "lineHeight": 1.2
      },
      "h3": {
        "desktop": "1.5rem",
        "mobile": "1.25rem",
        "lineHeight": 1.3
      },
      "body": {
        "desktop": "1rem",
        "mobile": "1rem",
        "lineHeight": 1.65
      },
      "small": {
        "desktop": "0.875rem",
        "mobile": "0.875rem",
        "lineHeight": 1.5
      }
    }
  },
  "colors": {
    "background": "{{color_background}}",
    "surface": "{{color_surface}}",
    "surfaceAlt": "{{color_surface_alt}}",
    "text": "{{color_text}}",
    "textMuted": "{{color_text_muted}}",
    "primary": "{{color_primary}}",
    "primaryContrast": "{{color_primary_contrast}}",
    "secondary": "{{color_secondary}}",
    "secondaryContrast": "{{color_secondary_contrast}}",
    "accent": "{{color_accent}}",
    "border": "{{color_border}}",
    "success": "{{color_success}}",
    "warning": "{{color_warning}}"
  },
  "semanticRoles": {
    "mainCta": "primary",
    "secondaryCta": "secondary",
    "trustHighlights": "accent",
    "localProof": "surfaceAlt",
    "faqBackground": "surface",
    "footerBackground": "{{color_footer_bg}}"
  },
  "buttons": {
    "primary": {
      "padding": "0.875rem 1.25rem",
      "radius": "999px",
      "fontWeight": 600,
      "shadow": "md"
    },
    "secondary": {
      "padding": "0.875rem 1.25rem",
      "radius": "999px",
      "fontWeight": 600,
      "borderWidth": "1px"
    }
  },
  "forms": {
    "inputHeight": "48px",
    "textareaMinHeight": "140px",
    "labelWeight": 600,
    "fieldGap": "1rem",
    "submitStyle": "primary"
  },
  "cards": {
    "serviceCard": {
      "radius": "lg",
      "padding": "1.5rem",
      "shadow": "sm"
    },
    "reviewCard": {
      "radius": "lg",
      "padding": "1.5rem",
      "shadow": "sm"
    },
    "articleCard": {
      "radius": "lg",
      "padding": "1.25rem",
      "shadow": "sm"
    }
  },
  "seoUi": {
    "breadcrumbsVisible": true,
    "quickAnswerBlockPreferred": true,
    "faqAccordionPreferred": true,
    "reviewSummaryBlockPreferred": true,
    "stickyMobileCta": false,
    "napVisibleInFooter": true,
    "phoneVisibleInHeader": true
  },
  "pageTemplates": {
    "homepage": {
      "heroRequired": true,
      "serviceGridRequired": true,
      "trustBlockRequired": true,
      "ctaBlockRequired": true,
      "faqBlockRecommended": true,
      "napBlockRequired": true
    },
    "serviceOverview": {
      "audioSectionsRequired": true,
      "faqBlockRequired": true,
      "localVariantsBlockRequired": true,
      "ctaBlockRequired": true
    },
    "locationService": {
      "geoIntroRequired": true,
      "localProofBlockRequired": true,
      "audioSectionsRequired": true,
      "faqBlockRequired": true,
      "cityClusterLinksRequired": true,
      "ctaBlockRequired": true
    },
    "additionalCategory": {
      "audioSectionsRequired": true,
      "voiceSearchFaqRequired": true,
      "cityClusterLinksRequired": true,
      "ctaBlockRequired": true
    },
    "geoHub": {
      "cityIntroRequired": true,
      "cityServiceGridRequired": true,
      "cityResourcesRequired": true,
      "ctaBlockRequired": true
    },
    "geoArticle": {
      "contextualIntroRequired": true,
      "faqBlockRequired": true,
      "internalCtaRequired": true,
      "clusterLinksRequired": true
    }
  }
}